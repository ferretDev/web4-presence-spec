    "action:type": "purchase",
    "action:label": "Get Dossier",
    "action:endpoint": "https://ferretdev.com/products/dossier"
  }
}
```

### 22.5 Person

```json
{
  "meta:schema": "https://web4presence.org/schema/2026-04-25",
  "meta:type": "Person",
  "meta:version": "0.2",
  "meta:updated": "2026-04-25T14:00:00Z",
  "meta:language": "en-CA",
  "meta:ttl": 86400,

  "identity:name": "Shawn McGinnis",
  "identity:type": "Person",
  "identity:tagline": "WordPress developer and agency tooling builder",
  "identity:url": "https://ferretdev.com",

