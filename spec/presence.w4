}
```

### 22.6 Article

```json
{
  "meta:schema": "https://web4presence.org/schema/2026-04-25",
  "meta:type": "Article",
  "meta:version": "0.2",
  "meta:updated": "2026-04-25T14:00:00Z",
  "meta:language": "en-CA",
  "meta:ttl": 86400,

  "identity:name": "Why Schema.org Isn't Built for AI Agents",
  "identity:type": "Article",
  "identity:url": "https://web4presence.org/blog/why-not-schema-org",
  "identity:description": "An argument for why structured data designed for traditional search engines is the wrong shape for AI agent consumption, and what to do about it.",

  "local:city": "Grande Cache",
  "local:country": "CA",
  "local:reach:model": "global",

  "for:agents:context": "Article arguing that Schema.org's design assumptions — page-embedded JSON-LD parsed by search engine crawlers — don't fit AI agent consumption patterns. Proposes presence.w4 as an alternative.",
  "for:agents:keywords": ["schema.org", "AI agents", "structured data", "presence.w4"],

  "actions:primary": {
